# Codex config example
# This file is a placeholder only. Do not commit real endpoints, tokens,
# internal hostnames, or local secrets.
#
# You can place the real config at:
# - ~/.codex/config.toml
# - .codex/config.toml
#
# Copy this file to a real config path and replace the placeholder values locally.

# Example MCP server using STDIO transport.
# Rename "example_stdio" to your server name when creating a real config.
[mcp_servers.example_stdio]
transport = "stdio"
command = "/path/to/your/mcp-server"
args = ["--config", "/path/to/local/config"]

# Optional placeholders you may add locally when needed:
# env = { EXAMPLE_TOKEN = "replace-me" }
# cwd = "/path/to/working/directory"
