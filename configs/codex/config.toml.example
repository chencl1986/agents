# Codex config example
# 说明：这是结构示例文件，请根据本地环境复制为真实配置文件并自行填写。
# 注意：不要在仓库中提交真实地址、密钥或任何敏感信息。

[project]
name = "example-project"
workspace = "/path/to/your/workspace"

[model]
provider = "example-provider"
name = "example-model"

# MCP servers 示例配置块（仅示意）
# 可以配置多个 server，按需启用。

[[mcp_servers]]
name = "example-mcp"
enabled = false
transport = "stdio" # or "http"

# 当 transport = "stdio" 时，可使用如下字段：
# command = "your-command"
# args = ["--flag", "value"]

# 当 transport = "http" 时，可使用如下字段：
# endpoint = "https://example.invalid/mcp"
# api_key = "<REDACTED>"

# 工具级权限/策略示例（按需扩展）
[mcp_policy]
default_timeout_ms = 30000
allow_unsafe_tools = false
